{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://devarch.io/schemas/workspace.schema.json",
  "title": "DevArch V2 Workspace",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "resources"],
  "properties": {
    "apiVersion": {
      "const": "devarch.io/v2alpha1"
    },
    "kind": {
      "const": "Workspace"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "displayName": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "provider": {
          "type": "string",
          "enum": ["auto", "docker", "podman"]
        },
        "isolatedNetwork": {
          "type": "boolean"
        },
        "namingStrategy": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "catalog": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "sources": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "policies": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "autoWire": {
          "type": "boolean"
        },
        "secretSource": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "secrets": {
      "type": "object",
      "additionalProperties": true
    },
    "profiles": {
      "type": "object",
      "additionalProperties": true
    },
    "resources": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "pattern": "^[a-z0-9][a-z0-9-]*$"
      },
      "additionalProperties": {
        "$ref": "#/definitions/resource"
      }
    }
  },
  "definitions": {
    "secretRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["secretRef"],
      "properties": {
        "secretRef": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "envValue": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "number"
        },
        {
          "type": "boolean"
        },
        {
          "$ref": "#/definitions/secretRef"
        }
      ]
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "path"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["project", "raw-compose"]
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "service": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "port": {
      "type": "object",
      "additionalProperties": false,
      "required": ["container"],
      "properties": {
        "host": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "container": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "protocol": {
          "type": "string",
          "enum": ["tcp", "udp"]
        },
        "hostIP": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "volume": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target"],
      "properties": {
        "source": {
          "type": "string",
          "minLength": 1
        },
        "target": {
          "type": "string",
          "minLength": 1
        },
        "readOnly": {
          "type": "boolean"
        },
        "kind": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "import": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contract"],
      "properties": {
        "contract": {
          "type": "string",
          "minLength": 1
        },
        "from": {
          "type": "string",
          "minLength": 1
        },
        "alias": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "export": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["contract"],
          "properties": {
            "contract": {
              "type": "string",
              "minLength": 1
            },
            "env": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            }
          }
        }
      ]
    },
    "health": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "test": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          ]
        },
        "interval": {
          "type": "string",
          "minLength": 1
        },
        "timeout": {
          "type": "string",
          "minLength": 1
        },
        "retries": {
          "type": "integer",
          "minimum": 1
        },
        "startPeriod": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "resource": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "template": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "$ref": "#/definitions/source"
        },
        "enabled": {
          "type": "boolean"
        },
        "env": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/definitions/envValue"
          }
        },
        "ports": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/port"
          }
        },
        "volumes": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/volume"
          }
        },
        "dependsOn": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "imports": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/import"
          }
        },
        "exports": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/export"
          }
        },
        "health": {
          "$ref": "#/definitions/health"
        },
        "domains": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "develop": {
          "type": "object",
          "additionalProperties": true
        },
        "overrides": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "anyOf": [
        {
          "required": ["template"]
        },
        {
          "required": ["source"]
        }
      ]
    }
  }
}
