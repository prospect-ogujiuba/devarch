{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://devarch.io/schemas/plan.schema.json",
  "title": "DevArch V2 Plan",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "actions"],
  "properties": {
    "apiVersion": {
      "const": "devarch.io/v2alpha1"
    },
    "kind": {
      "const": "Plan"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["workspace"],
      "properties": {
        "workspace": {
          "type": "string",
          "minLength": 1
        },
        "generatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "runtimeProvider": {
          "type": "string",
          "enum": ["auto", "docker", "podman"]
        }
      }
    },
    "actions": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/action"
      }
    }
  },
  "definitions": {
    "action": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action", "resource", "reason"],
      "properties": {
        "action": {
          "type": "string",
          "enum": ["add", "modify", "remove", "restart", "noop"]
        },
        "resource": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "details": {
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  }
}
