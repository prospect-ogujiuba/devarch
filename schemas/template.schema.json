{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://devarch.io/schemas/template.schema.json",
  "title": "DevArch V2 Template",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": {
      "const": "devarch.io/v2alpha1"
    },
    "kind": {
      "const": "Template"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "tags": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "description": {
          "type": "string"
        }
      }
    },
    "spec": {
      "$ref": "#/definitions/spec"
    }
  },
  "definitions": {
    "secretRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["secretRef"],
      "properties": {
        "secretRef": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "envValue": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "number"
        },
        {
          "type": "boolean"
        },
        {
          "$ref": "#/definitions/secretRef"
        }
      ]
    },
    "stringOrStringArray": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      ]
    },
    "build": {
      "type": "object",
      "additionalProperties": false,
      "required": ["context"],
      "properties": {
        "context": {
          "type": "string",
          "minLength": 1
        },
        "dockerfile": {
          "type": "string",
          "minLength": 1
        },
        "target": {
          "type": "string",
          "minLength": 1
        },
        "args": {
          "type": "object",
          "additionalProperties": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "number"
              },
              {
                "type": "boolean"
              }
            ]
          }
        }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "image": {
          "type": "string",
          "minLength": 1
        },
        "build": {
          "$ref": "#/definitions/build"
        },
        "command": {
          "$ref": "#/definitions/stringOrStringArray"
        },
        "entrypoint": {
          "$ref": "#/definitions/stringOrStringArray"
        },
        "workingDir": {
          "type": "string",
          "minLength": 1
        }
      },
      "anyOf": [
        {
          "required": ["image"]
        },
        {
          "required": ["build"]
        }
      ]
    },
    "port": {
      "type": "object",
      "additionalProperties": false,
      "required": ["container"],
      "properties": {
        "host": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "container": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "protocol": {
          "type": "string",
          "enum": ["tcp", "udp"]
        },
        "hostIP": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "volume": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target"],
      "properties": {
        "source": {
          "type": "string",
          "minLength": 1
        },
        "target": {
          "type": "string",
          "minLength": 1
        },
        "readOnly": {
          "type": "boolean"
        },
        "kind": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "import": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contract"],
      "properties": {
        "contract": {
          "type": "string",
          "minLength": 1
        },
        "from": {
          "type": "string",
          "minLength": 1
        },
        "alias": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "export": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["contract"],
          "properties": {
            "contract": {
              "type": "string",
              "minLength": 1
            },
            "env": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            }
          }
        }
      ]
    },
    "health": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "test": {
          "$ref": "#/definitions/stringOrStringArray"
        },
        "interval": {
          "type": "string",
          "minLength": 1
        },
        "timeout": {
          "type": "string",
          "minLength": 1
        },
        "retries": {
          "type": "integer",
          "minimum": 1
        },
        "startPeriod": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["runtime"],
      "properties": {
        "runtime": {
          "$ref": "#/definitions/runtime"
        },
        "env": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/definitions/envValue"
          }
        },
        "ports": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/port"
          }
        },
        "volumes": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/volume"
          }
        },
        "imports": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/import"
          }
        },
        "exports": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/export"
          }
        },
        "health": {
          "$ref": "#/definitions/health"
        },
        "develop": {
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  }
}
