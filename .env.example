# =============================================================================
# MICROSERVICES ENVIRONMENT CONFIGURATION - HYBRID APPROACH
# =============================================================================
# This file contains ONLY sensitive data and truly shared values
# Service-specific non-sensitive configs are in individual compose files

# =============================================================================
# GLOBAL ADMIN CONFIGURATION
# =============================================================================
ADMIN_USER=admin
ADMIN_PASSWORD=admin1234567
ADMIN_EMAIL=admin@devarch.test

# =============================================================================
# DOMAIN CONFIGURATION
# =============================================================================
DOMAIN_SUFFIX=test

# =============================================================================
# DEVARCH API KEY
# =============================================================================
DEVARCH_API_KEY=your-api-key-here

# =============================================================================
# CORS ALLOWED ORIGINS (comma-separated, leave empty for permissive)
# =============================================================================
ALLOWED_ORIGINS=http://localhost:5174

# =============================================================================
# SECURITY MODE
# =============================================================================
# Security mode: dev-open (no auth), dev-keyed (API key required), strict (API key + WS token)
SECURITY_MODE=dev-open

# =============================================================================
# DEVELOPMENT CREDENTIALS
# =============================================================================
GITHUB_USER=github-user
GITHUB_TOKEN=github-token

# =============================================================================
# MARIADB CREDENTIALS
# =============================================================================
MARIADB_HOST=mariadb
MARIADB_PORT=3306
MYSQL_ROOT_PASSWORD=admin1234567
MYSQL_USER=mariadb_user
MYSQL_PASSWORD=admin1234567

# =============================================================================
# NGINX PROXY MANAGER CREDENTIALS
# =============================================================================
DB_MYSQL_HOST=mariadb
DB_MYSQL_PORT=3306
DB_MYSQL_USER=root
DB_MYSQL_PASSWORD=admin1234567
DB_MYSQL_NAME=npm
INITIAL_ADMIN_EMAIL=admin@devarch.test
INITIAL_ADMIN_PASSWORD=admin1234567
